# Variables de build (Vite las inyecta en el bundle: prefijo VITE_).
# Copiá a .env para desarrollo local. En CI/preview se setean como GitHub Secrets /
# variables de Railway, NUNCA se commitean valores reales.

# Firebase (autenticación). Son credenciales de cliente (públicas por diseño),
# pero igual configurás el proyecto por entorno.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGE_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# URL base de la API.
#  - Local / preview sin backend: dejala vacía y la app usa el mock de src/__mock__.
#  - Preview full-stack en Railway: apuntá a la API efímera del PR. Ejemplo con variable
#    de referencia de Railway (servicio "api" del mismo environment):
#    VITE_API_BASE_URL="https://${{ api.RAILWAY_PUBLIC_DOMAIN }}"
VITE_API_BASE_URL=""
