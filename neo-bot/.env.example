# ─── Neo bot · variables de entorno ───────────────────────────────────────────
# Copiá a .env para desarrollo local. En Railway se cargan como variables del servicio.
# NUNCA commitees valores reales.

# ── Matrix ──
NEO_MATRIX_HOMESERVER="https://matrix.org"
NEO_MATRIX_USER_ID="@neo:tu-homeserver.org"
# Autenticá con UNO de los dos (preferí access token):
NEO_MATRIX_ACCESS_TOKEN=""
NEO_MATRIX_PASSWORD=""
NEO_MATRIX_DEVICE_ID="NEO_BOT"
# Salas permitidas (IDs, separadas por coma). Vacío = todas las salas donde esté el bot.
NEO_MATRIX_ROOMS=""
# Sala por defecto para reportes sin correlación (PR abierto/cerrado).
NEO_MATRIX_DEFAULT_ROOM=""
# Usuarios autorizados a dar órdenes (IDs, coma). Vacío = cualquiera de las salas permitidas.
NEO_MATRIX_ALLOWED_SENDERS=""

# ── GitHub App neo-bot ──
NEO_GITHUB_APP_ID="123456"
# La private key (.pem) entera. En Railway pegá el contenido multilínea tal cual.
NEO_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
NEO_GITHUB_INSTALLATION_ID="12345678"
NEO_GITHUB_WORKFLOW_FILE="neo.yml"
NEO_GITHUB_DEFAULT_REF="main"
# Secreto del webhook de la App (para verificar firmas X-Hub-Signature-256).
NEO_GITHUB_WEBHOOK_SECRET=""

# Repos autorizados: alias=owner/repo separados por coma.
NEO_REPOS="uko-vue=mi-org/uko-vue,api=mi-org/api_portal_cliente"

# ── Railway (para bajar previews) ──
NEO_RAILWAY_API_TOKEN=""
NEO_RAILWAY_PROJECT_ID=""
NEO_RAILWAY_GRAPHQL_URL="https://backboard.railway.com/graphql/v2"

# ── Jira (opcional, apagado por defecto) ──
NEO_JIRA_ENABLED="false"
NEO_JIRA_WEBHOOK_SECRET=""
# Mapeo KEY de proyecto Jira -> alias de repo. Ej: PORTAL=uko-vue,API=api
NEO_JIRA_PROJECT_REPO=""

# ── Server / logging ──
# PORT lo inyecta Railway automáticamente; en local default 8080.
PORT="8080"
NEO_LOG_LEVEL="INFO"
